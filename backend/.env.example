# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/prama

# Gemini AI API Key
# Get your API key from: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=your_gemini_api_key_here

# Encryption Key (32 bytes - required for AES-256-CBC)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex').slice(0,32))"
ENCRYPTION_KEY=your_32_character_encryption_key_here

# Server Port
PORT=5000
